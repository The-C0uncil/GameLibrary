@{
    Layout = null; // Standalone page, no shared layout
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login — Game Library</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded" rel="stylesheet">
    <style>
            :root {
                --accent: #e8b04b;
                --surface: #16213e;
                --bg: #0f1628;
            }

            html,
            body {
                height: 100%;
                margin: 0;
                background: var(--bg);
                font-family: Roboto, sans-serif;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                width: 100%;
                max-width: 380px;
                background: var(--surface);
                border-radius: 16px;
                padding: 2.5rem 2rem;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            }

            .login-logo {
                font-size: 2rem;
                color: var(--accent);
                margin-bottom: 0.25rem;
            }

            .login-title {
                font-size: 1.3rem;
                font-weight: 700;
                color: #f0f0f0;
                margin-bottom: 0.25rem;
            }

            .login-subtitle {
                font-size: 0.82rem;
                color: #8a8fa8;
                margin-bottom: 2rem;
            }

            .form-label {
                font-size: 0.78rem;
                font-weight: 600;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                color: #8a8fa8;
                margin-bottom: 0.35rem;
            }

            .form-control {
                background: #0f1628;
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 8px;
                color: #f0f0f0;
                padding: 0.6rem 0.85rem;
                font-size: 0.9rem;
                transition: border-color 0.15s;
            }

            .form-control:focus {
                background: #0f1628;
                border-color: rgba(232, 176, 75, 0.5);
                box-shadow: 0 0 0 3px rgba(232, 176, 75, 0.12);
                color: #f0f0f0;
            }

            .form-control::placeholder {
                color: #3a3f55;
            }

            .btn-login {
                width: 100%;
                background: var(--accent);
                border: none;
                border-radius: 8px;
                color: #1a1000;
                font-weight: 700;
                font-size: 0.9rem;
                padding: 0.65rem;
                margin-top: 0.5rem;
                transition: filter 0.15s, transform 0.15s;
            }

            .btn-login:hover {
                filter: brightness(1.1);
                transform: translateY(-1px);
            }

            .alert-error {
                background: rgba(200, 40, 40, 0.18);
                border: 1px solid rgba(200, 40, 40, 0.4);
                border-radius: 8px;
                color: #ff8a80;
                font-size: 0.82rem;
                padding: 0.6rem 0.85rem;
                margin-bottom: 1.25rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }
    </style>
</head>
<body>
    <div class="login-card">

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">
                <span class="material-symbols-rounded" style="font-size:17px">error</span>
                @ViewBag.Error
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl">

            <div class="mb-3">
                <label class="form-label" for="username">Username</label>
                <input type="text" class="form-control" id="username" name="username" placeholder="Enter username" autocomplete="username" required autofocus>
            </div>

            <div class="mb-4">
                <label class="form-label" for="password">Password</label>
                <input type="password" class="form-control" id="password" name="password" placeholder="Enter password" autocomplete="current-password" required>
            </div>

            <button type="submit" class="btn-login">Sign in</button>
        </form>
    </div>
</body>

</html>