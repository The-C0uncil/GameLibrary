<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Council</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&family=Grenze+Gotisch&display=swap" rel="stylesheet">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=add,arrow_back,article,check,chevron_left,chevron_right,close,delete,edit,group,handshake,history,inventory_2,mail,person,schedule,search,shopping_cart,star,thumb_up,tune" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>

    <!-- Side drawer backdrop (outside navbar, at body level) -->
    <div class="nav-drawer-backdrop" id="navDrawerBackdrop"></div>

    <!-- Side drawer (outside navbar so it never interferes with layout flow) -->
    <div id="navMenu">
        <button class="nav-drawer-close" id="navDrawerClose" aria-label="Close menu">
            <span class="material-symbols-rounded">close</span>
        </button>
        <a href="/Home/RentalHistory" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1">
            <span class="material-symbols-rounded" style="font-size:18px">history</span>
            Rentals
        </a>
        <a href="/Games/Index" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1">
            <span class="material-symbols-rounded" style="font-size:18px">article</span>
            Management
        </a>
    </div>

    <nav class="navbar navbar-dark">
        <div class="container-fluid">

            <!-- Brand -->
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <img src="~/images/logo.png" alt="Logo" style="height: 30px;">
                <span style="font-family: 'Grenze Gotisch', serif; font-size: 1.35rem; letter-spacing: 0.03em; color: var(--accent); line-height: 1;">The Council</span>
            </a>

            <!-- Right side: cart + hamburger -->
            <div class="d-flex align-items-center gap-2 ms-auto">

                <!-- Cart (home page only) -->
                <div class="nav-cart-wrap" id="navCartWrap" style="display:none">
                    <button class="nav-cart-btn" id="navCartBtn" aria-label="Cart" title="Selected games">
                        <span class="material-symbols-rounded">shopping_cart</span>
                        <span class="cart-badge" id="cartBadge" style="display:none">0</span>
                    </button>
                    <div class="cart-dropdown" id="cartDropdown" aria-hidden="true">
                        <p class="cart-dropdown-label">Selected Games</p>
                        <div id="cartDropdownList" class="cart-dropdown-list">
                            <p class="cart-empty-msg">No games selected</p>
                        </div>
                        <div class="cart-dropdown-footer">
                            <button class="btn btn-success btn-sm w-100 d-flex align-items-center justify-content-center gap-2"
                                    id="cartOrderBtn" disabled>
                                Order
                                <span class="material-symbols-rounded" style="font-size:18px">handshake</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Hamburger -->
                <button class="navbar-toggler" type="button" id="navToggler" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>

        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        // ── Side drawer ───────────────────────────
        const navToggler  = document.getElementById('navToggler');
        const navMenu     = document.getElementById('navMenu');
        const navBackdrop = document.getElementById('navDrawerBackdrop');
        const navClose    = document.getElementById('navDrawerClose');

        function openDrawer()  { navMenu.classList.add('show');    navBackdrop.classList.add('open');    }
        function closeDrawer() { navMenu.classList.remove('show'); navBackdrop.classList.remove('open'); }

        navToggler.addEventListener('click',  openDrawer);
        navClose.addEventListener('click',    closeDrawer);
        navBackdrop.addEventListener('click', closeDrawer);
        navMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));

        // ── Cart ──────────────────────────────────
        if (document.getElementById('rentModal')) {
            document.getElementById('navCartWrap').style.display = '';

            const cartBtn      = document.getElementById('navCartBtn');
            const cartDropdown = document.getElementById('cartDropdown');
            const cartOrderBtn = document.getElementById('cartOrderBtn');

            cartBtn.addEventListener('click', e => {
                e.stopPropagation();
                const open = cartDropdown.classList.toggle('open');
                cartDropdown.setAttribute('aria-hidden', String(!open));
            });

            document.addEventListener('click', e => {
                if (!e.target.closest('#navCartWrap')) {
                    cartDropdown.classList.remove('open');
                    cartDropdown.setAttribute('aria-hidden', 'true');
                }
            });

            cartOrderBtn.addEventListener('click', () => {
                cartDropdown.classList.remove('open');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('rentModal')).show();
            });
        }

        // Called by site.js whenever selectedGames changes
        function updateCartUI(selectedGames) {
            const badge = document.getElementById('cartBadge');
            const list  = document.getElementById('cartDropdownList');
            if (!badge || !list) return;

            const count = selectedGames.length;
            badge.textContent   = count;
            badge.style.display = count > 0 ? '' : 'none';

            list.innerHTML = count === 0
                ? '<p class="cart-empty-msg">No games selected</p>'
                : selectedGames.map(g =>
                    `<div class="cart-item">
                        <span class="cart-item-name">${g.name}</span>
                        <button class="cart-item-remove" onclick="window.cartRemove(${g.id})" aria-label="Remove">
                            <span class="material-symbols-rounded">close</span>
                        </button>
                    </div>`).join('');

            const orderBtn = document.getElementById('cartOrderBtn');
            if (orderBtn) orderBtn.disabled = count === 0;
        }
    </script>
</body>
</html>
